* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary: #4CAF50;
  --primary-dark: #45a049;
  --secondary: #2196F3;
  --danger: #f44336;
  --warning: #ff9800;
  --bg-dark: #121212;
  --bg-card: #1e1e1e;
  --bg-hover: #2a2a2a;
  --text-primary: #ffffff;
  --text-secondary: #b0b0b0;
  --border: #333333;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  background: var(--bg-dark);
  color: var(--text-primary);
  min-height: 100vh;
  line-height: 1.6;
}

#app {
  max-width: 600px;
  margin: 0 auto;
  padding: 16px;
}

header {
  margin-bottom: 24px;
}

header h1 {
  font-size: 24px;
  margin-bottom: 16px;
  text-align: center;
}

#main-nav {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
}

.nav-btn {
  padding: 10px 20px;
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 14px;
  font-weight: 500;
}

.nav-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.nav-btn.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

#main-content {
  min-height: 400px;
}

.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 16px;
}

.card h2 {
  font-size: 20px;
  margin-bottom: 16px;
  color: var(--primary);
}

.card h3 {
  font-size: 16px;
  margin-bottom: 12px;
  color: var(--text-secondary);
}

.weekly-schedule {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
  margin-bottom: 16px;
}

.day-card {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px 8px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
}

.day-card:hover {
  border-color: var(--primary);
}

.day-card.today {
  border-color: var(--primary);
  background: rgba(76, 175, 80, 0.1);
}

.day-card.rest-day {
  opacity: 0.6;
}

.day-name {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.day-number {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 4px;
}

.day-focus {
  font-size: 10px;
  color: var(--primary);
}

.btn {
  padding: 12px 24px;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  width: 100%;
}

.btn-primary {
  background: var(--primary);
  color: white;
}

.btn-primary:hover {
  background: var(--primary-dark);
}

.btn-secondary {
  background: var(--secondary);
  color: white;
}

.btn-danger {
  background: var(--danger);
  color: white;
}

.exercise-list {
  list-style: none;
}

.exercise-item {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}

.exercise-name {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 8px;
  color: var(--primary);
}

.exercise-details {
  display: flex;
  gap: 16px;
  font-size: 14px;
  color: var(--text-secondary);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin-bottom: 16px;
}

.stat-box {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  text-align: center;
}

.stat-value {
  font-size: 28px;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 4px;
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: var(--text-secondary);
}

.empty-state-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

@media (max-width: 480px) {
  .weekly-schedule {
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  
  .day-card {
    padding: 8px 4px;
  }
  
  .day-name {
    font-size: 10px;
  }
  
  .day-number {
    font-size: 14px;
  }
  
  .day-focus {
    font-size: 9px;
  }
}

/* Workout Session Styles */
.workout-progress {
  margin-top: 12px;
}

.progress-bar {
  width: 100%;
  height: 12px;
  background: var(--bg-hover);
  border-radius: 6px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 6px;
  transition: width 0.3s ease;
}

.current-exercise {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 20px;
  text-align: center;
}

.current-exercise .exercise-name {
  font-size: 24px;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 12px;
}

.current-exercise .exercise-details {
  font-size: 18px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.rest-info {
  font-size: 14px;
  color: var(--warning);
  margin-top: 8px;
}

.timer-section {
  text-align: center;
  margin: 24px 0;
}

.timer-display {
  font-size: 48px;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16px;
  font-family: 'Courier New', monospace;
}

.timer-display.timer-complete {
  color: var(--primary);
  animation: pulse 0.5s ease-in-out 3;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.timer-controls {
  display: flex;
  gap: 12px;
  justify-content: center;
}

.workout-controls {
  margin-top: 24px;
}

/* History Styles */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-item {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
}

.history-date {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.history-name {
  font-size: 18px;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8px;
}

.history-details {
  display: flex;
  gap: 16px;
  font-size: 14px;
  color: var(--text-secondary);
}

/* Responsive adjustments */
@media (max-width: 480px) {
  .current-exercise .exercise-name {
    font-size: 20px;
  }
  
  .timer-display {
    font-size: 36px;
  }
}

/* Workout Session Styles */
.workout-progress {
  margin-top: 16px;
}

.progress-bar {
  width: 100%;
  height: 12px;
  background: var(--bg-hover);
  border-radius: 6px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  transition: width 0.3s ease;
}

.current-exercise {
  text-align: center;
  padding: 24px 16px;
  background: var(--bg-hover);
  border-radius: 12px;
  margin-bottom: 20px;
}

.current-exercise .exercise-name {
  font-size: 24px;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 12px;
}

.current-exercise .exercise-details {
  font-size: 18px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.rest-info {
  font-size: 14px;
  color: var(--warning);
  margin-top: 8px;
}

.timer-section {
  text-align: center;
  margin: 24px 0;
}

.timer-display {
  font-size: 64px;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16px;
  font-family: 'Courier New', monospace;
}

.timer-display.timer-complete {
  color: var(--primary);
  animation: pulse 0.5s ease-in-out;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.timer-controls {
  margin-top: 16px;
}

.workout-controls {
  margin-top: 24px;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-item {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
}

.history-date {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 4px;
}

.history-name {
  font-size: 18px;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 8px;
}

.history-details {
  display: flex;
  gap: 16px;
  font-size: 14px;
  color: var(--text-secondary);
}

.day-card.has-workout {
  border-color: var(--primary);
}

/* Phase 4: Timer Enhancements */
.timer-circle {
  position: relative;
  width: 200px;
  height: 200px;
  margin: 20px auto;
}

.timer-svg {
  width: 100%;
  height: 100%;
  transform: rotate(-90deg);
}

.timer-circle-bg {
  fill: none;
  stroke: var(--bg-hover);
  stroke-width: 8;
}

.timer-circle-progress {
  fill: none;
  stroke: var(--primary);
  stroke-width: 8;
  stroke-linecap: round;
  transition: stroke-dashoffset 0.3s ease;
}

.timer-display {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48px;
  font-weight: bold;
  color: var(--text-primary);
  font-family: 'Courier New', monospace;
}

.timer-presets {
  display: flex;
  gap: 8px;
  justify-content: center;
  margin: 16px 0;
  flex-wrap: wrap;
}

.preset-btn {
  padding: 8px 16px;
  background: var(--bg-hover);
  color: var(--text-primary);
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 14px;
  font-weight: 600;
}

.preset-btn:hover {
  background: var(--primary);
  border-color: var(--primary);
  color: white;
}

.preset-btn:active {
  transform: scale(0.95);
}

.timer-controls {
  margin-top: 16px;
}

#custom-timer {
  padding: 12px;
  width: 100%;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg-hover);
  color: var(--text-primary);
  font-size: 16px;
  margin-top: 12px;
}

#custom-timer:focus {
  outline: none;
  border-color: var(--primary);
}

.timer-display.timer-complete {
  color: var(--primary);
  animation: pulse 0.5s ease-in-out;
}

@keyframes pulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); }
  50% { transform: translate(-50%, -50%) scale(1.1); }
}

/* Phase 5: Progress Page */
.weight-display {
  text-align: center;
  padding: 20px 0;
}

.weight-current {
  margin-bottom: 8px;
}

.weight-value {
  font-size: 48px;
  font-weight: bold;
  color: var(--primary);
}

.weight-unit {
  font-size: 20px;
  color: var(--text-secondary);
  margin-left: 4px;
}

.weight-change {
  font-size: 16px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 12px;
  display: inline-block;
}

.weight-loss {
  color: var(--primary);
  background: rgba(76, 175, 80, 0.15);
}

.weight-gain {
  color: var(--warning);
  background: rgba(255, 152, 0, 0.15);
}

.weekly-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 120px;
  padding: 16px 0;
  gap: 12px;
}

.week-bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.bar-fill {
  width: 100%;
  max-width: 40px;
  background: var(--primary);
  border-radius: 6px 6px 0 0;
  min-height: 4px;
  transition: height 0.3s ease;
}

.bar-label {
  margin-top: 8px;
  font-size: 12px;
  color: var(--text-secondary);
}

.weekly-summary {
  text-align: center;
  color: var(--text-secondary);
  font-size: 14px;
  padding-top: 8px;
  border-top: 1px solid var(--border);
}

.measurements-list {
  margin-top: 16px;
}

.measurement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: var(--bg-hover);
  border-radius: 8px;
  margin-bottom: 8px;
}

.measurement-type {
  font-weight: 600;
  color: var(--text-primary);
  text-transform: capitalize;
}

.measurement-value {
  color: var(--primary);
  font-weight: 600;
}

.measurement-date {
  font-size: 12px;
  color: var(--text-secondary);
}

/* Modal */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 16px;
}

.modal-content {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  width: 100%;
  max-width: 400px;
}

.modal-content h3 {
  margin-bottom: 16px;
  color: var(--primary);
}

.modal-content input,
.modal-content select {
  width: 100%;
  padding: 12px;
  margin-bottom: 12px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg-hover);
  color: var(--text-primary);
  font-size: 16px;
}

.modal-content input:focus,
.modal-content select:focus {
  outline: none;
  border-color: var(--primary);
}

.modal-buttons {
  display: flex;
  gap: 12px;
  margin-top: 8px;
}

.modal-buttons .btn {
  flex: 1;
}

/* Phase 5: Progress Tracking Styles */
.weight-display {
  text-align: center;
  padding: 20px;
  background: var(--bg-hover);
  border-radius: 12px;
  margin-bottom: 16px;
}

.weight-current {
  margin-bottom: 8px;
}

.weight-value {
  font-size: 48px;
  font-weight: bold;
  color: var(--primary);
}

.weight-unit {
  font-size: 24px;
  color: var(--text-secondary);
  margin-left: 4px;
}

.weight-change {
  font-size: 18px;
  font-weight: 600;
  padding: 8px 16px;
  border-radius: 8px;
  display: inline-block;
}

.weight-loss {
  background: rgba(76, 175, 80, 0.2);
  color: var(--primary);
}

.weight-gain {
  background: rgba(255, 152, 0, 0.2);
  color: var(--warning);
}

.weekly-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 150px;
  padding: 16px 0;
  gap: 8px;
}

.week-bar {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.bar-fill {
  width: 100%;
  max-width: 40px;
  background: var(--primary);
  border-radius: 8px 8px 0 0;
  transition: height 0.3s ease;
  min-height: 4px;
}

.bar-label {
  margin-top: 8px;
  font-size: 12px;
  color: var(--text-secondary);
  font-weight: 600;
}

.weekly-summary {
  text-align: center;
  padding: 12px;
  background: var(--bg-hover);
  border-radius: 8px;
  margin-top: 12px;
}

.weekly-summary p {
  color: var(--text-secondary);
  font-size: 14px;
}

.measurements-list {
  margin-top: 16px;
}

.measurement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: var(--bg-hover);
  border-radius: 8px;
  margin-bottom: 8px;
}

.measurement-type {
  font-weight: 600;
  color: var(--primary);
  text-transform: capitalize;
}

.measurement-value {
  font-size: 18px;
  font-weight: bold;
  color: var(--text-primary);
}

.measurement-date {
  font-size: 12px;
  color: var(--text-secondary);
}

/* Modal Styles */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 16px;
}

.modal-content {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  max-width: 400px;
  width: 100%;
}

.modal-content h3 {
  margin-bottom: 16px;
  color: var(--primary);
}

.modal-content input,
.modal-content select {
  width: 100%;
  padding: 12px;
  margin-bottom: 12px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg-hover);
  color: var(--text-primary);
  font-size: 16px;
}

.modal-content input:focus,
.modal-content select:focus {
  outline: none;
  border-color: var(--primary);
}

.modal-buttons {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}

.modal-buttons .btn {
  flex: 1;
}

/* Statistics Page Styles */
.stats-header {
  margin-bottom: 24px;
}

.stats-header h2 {
  font-size: 28px;
  color: var(--primary);
}

.stats-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.stats-section h3 {
  font-size: 18px;
  color: var(--text-primary);
  margin-bottom: 16px;
  border-bottom: 1px solid var(--border);
  padding-bottom: 8px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 16px;
}

.stat-card {
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  text-align: center;
}

.stat-value {
  font-size: 32px;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 4px;
}

.stat-label {
  font-size: 14px;
  color: var(--text-secondary);
}

.highlight-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 12px;
  padding: 24px;
  text-align: center;
}

.highlight-value {
  font-size: 24px;
  font-weight: bold;
  color: white;
  margin-bottom: 8px;
}

.highlight-label {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.9);
}

.exercise-ranking {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.ranking-item {
  display: flex;
  align-items: center;
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px;
}

.ranking-number {
  font-size: 20px;
  font-weight: bold;
  color: var(--primary);
  min-width: 40px;
}

.ranking-name {
  flex: 1;
  font-size: 16px;
  color: var(--text-primary);
}

.ranking-count {
  font-size: 18px;
  font-weight: bold;
  color: var(--secondary);
}

.bar-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200px;
  padding: 20px 0;
  gap: 8px;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
}

.bar-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.bar-container {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.bar-fill {
  width: 30px;
  background: var(--primary);
  border-radius: 4px 4px 0 0;
  transition: height 0.3s ease;
  min-height: 4px;
}

.bar-value {
  font-size: 14px;
  font-weight: bold;
  color: var(--text-primary);
  margin-top: 8px;
}

.line-chart {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 150px;
  padding: 20px 0;
  position: relative;
}

.line-point {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.point-dot {
  width: 12px;
  height: 12px;
  background: var(--primary);
  border-radius: 50%;
  border: 2px solid var(--bg-card);
  box-shadow: 0 0 0 2px var(--primary);
}

.point-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 8px;
}

.point-value {
  font-size: 14px;
  font-weight: bold;
  color: var(--text-primary);
  margin-top: 4px;
}

@media (max-width: 480px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .stat-value {
    font-size: 24px;
  }
  
  .bar-chart {
    height: 150px;
  }
  
  .bar-fill {
    width: 20px;
  }
}

/* Settings Page Styles */
.settings-section {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--border);
}

.settings-section:last-of-type {
  border-bottom: none;
}

.settings-section h3 {
  font-size: 18px;
  color: var(--text-primary);
  margin-bottom: 16px;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.setting-item label {
  font-size: 16px;
  color: var(--text-secondary);
}

.setting-item input[type="number"] {
  width: 100px;
  padding: 8px 12px;
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-primary);
  font-size: 16px;
}

.setting-item select {
  padding: 8px 12px;
  background: var(--bg-hover);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-primary);
  font-size: 16px;
  min-width: 150px;
}

/* Toggle Switch */
.switch {
  position: relative;
  display: inline-block;
  width: 50px;
  height: 26px;
}

.switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--border);
  transition: .3s;
  border-radius: 26px;
}

.slider:before {
  position: absolute;
  content: "";
  height: 20px;
  width: 20px;
  left: 3px;
  bottom: 3px;
  background-color: var(--text-primary);
  transition: .3s;
  border-radius: 50%;
}

input:checked + .slider {
  background-color: var(--primary);
}

input:checked + .slider:before {
  transform: translateX(24px);
}

.about-text {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.settings-section .btn {
  margin-bottom: 12px;
}
